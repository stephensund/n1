# ==== Target: ARMv8 (armsr) for N1 rootfs/pack ====
CONFIG_TARGET_armsr=y
CONFIG_TARGET_armsr_armv8=y
CONFIG_TARGET_armsr_armv8_DEVICE_generic=y

# 我们主要产出 rootfs，由打包脚本再生成 N1 IMG；此处不强制本机生成 initramfs/ext4/squashfs 镜像
CONFIG_TARGET_ROOTFS_INITRAMFS=n
CONFIG_TARGET_ROOTFS_CPIOGZ=n
CONFIG_TARGET_ROOTFS_EXT4FS=n
CONFIG_TARGET_ROOTFS_SQUASHFS=n

# -----------------------------
# LuCI & 主题/终端/存储
# -----------------------------
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-samba4=y

# Amlogic 盒子管理（安装到 eMMC、在线升级固件/内核、快照/备份）
CONFIG_PACKAGE_luci-app-amlogic=y

# -----------------------------
# 代理前端：OpenClash + Passwall（仅 Sing-Box 后端）
# -----------------------------
CONFIG_PACKAGE_luci-app-openclash=y

CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=y

# 关闭其它大体量后端，保持瘦身
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_v2ray_plugin=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_xray_plugin=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadow_TLS=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_tuic_client=n

# -----------------------------
# 不在 OpenWrt 内部再跑 Docker（OpenWrt 自身将运行在 Docker/LXC）
# -----------------------------
CONFIG_PACKAGE_luci-app-dockerman=n

# -----------------------------
# 打包/分区/文件系统 & 通用工具（为 N1 打包/刷写/在线升级保驾护航）
# —— 这些来源于 unifreq/flippy/ophub 的“必选软件包”思路 —— 
# -----------------------------
# 压缩/归档
CONFIG_PACKAGE_bsdtar=y
CONFIG_PACKAGE_pigz=y
CONFIG_PACKAGE_tar=y

# 磁盘/分区/loop
# （注意：某些条目可能由上游选择器自动拉起，这里列出关键位以确保可用）
# 如你需要 uuidgen，可在后续按需追加（常见在 util-linux 包内）
# 可选：blkid、fdisk、lsblk、parted、losetup 在不同源码树的包名位置略有差异，交给 feeds/defconfig 拉依赖

# 文件系统工具
CONFIG_PACKAGE_btrfs-progs=y
CONFIG_BTRFS_PROGS_ZSTD=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_xfs-fsck=y
CONFIG_PACKAGE_xfs-mkfs=y
CONFIG_PACKAGE_chattr=y
CONFIG_PACKAGE_lsattr=y

# 常用脚本
CONFIG_PACKAGE_gawk=y
CONFIG_PACKAGE_getopt=y
CONFIG_PACKAGE_perl-http-date=y
CONFIG_PACKAGE_perlbase-file=y
CONFIG_PACKAGE_perlbase-getopt=y
CONFIG_PACKAGE_perlbase-unicode=y

# 杂项（按你原配置保留）
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_zoneinfo-asia=y

# -----------------------------
# 可安全关闭（容器环境/或你已指定不用）
# -----------------------------
CONFIG_PACKAGE_partx-utils=n
CONFIG_PACKAGE_ppp=n
CONFIG_PACKAGE_shellsync=n

# 一些 kmod 在容器/LXC 下通常无效，但你原本保留了 kmod-usb2；留与否都不影响容器运行
CONFIG_PACKAGE_kmod-usb2=y
